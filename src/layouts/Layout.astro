---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, languages } from '../i18n';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title = t('site.title'), description = t('site.description') } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/Playful logo design for Nudges.png" />
    <link rel="apple-touch-icon" href="/Playful logo design for Nudges.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 min-h-screen flex flex-col">
    <nav class="flex items-center gap-6 px-8 py-4 border-b border-gray-100">
      <div class="mr-auto">
        <Logo href={getLocalizedPath('/', lang)} />
      </div>
      <div class="flex gap-6">
        <a href={getLocalizedPath('/#apps', lang)} class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
          {t('nav.apps')}
        </a>
        <a href={getLocalizedPath('/about', lang)} class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
          {t('nav.about')}
        </a>
      </div>
      <div class="flex gap-2 border-l border-gray-200 pl-4">
        {Object.entries(languages).map(([code, label]) => (
          <a
            href={code === 'en'
              ? Astro.url.pathname.replace(/^\/es(\/|$)/, '/') || '/'
              : `/es${Astro.url.pathname}`}
            class:list={[
              'text-xs px-2 py-1 rounded transition-colors',
              lang === code
                ? 'bg-gray-900 text-white'
                : 'text-gray-400 hover:text-gray-700'
            ]}
          >
            {label}
          </a>
        ))}
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="py-8 text-center text-xs text-gray-400 border-t border-gray-100">
      {t('footer.made_with')} ♥ {t('footer.for')}
    </footer>
  </body>
</html>
