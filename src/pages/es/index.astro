---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('es');
---

<Layout>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-8 pt-24 pb-16 text-center">
    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-tight mb-4 whitespace-pre-line">
      {t('home.hero_title')}
    </h1>
    <p class="text-lg text-gray-500 mb-8 max-w-md mx-auto">
      {t('home.hero_subtitle')}
    </p>
    <a
      href="#apps"
      class="inline-block bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-700 transition-colors"
    >
      {t('home.browse_apps')}
    </a>
  </section>

  <!-- Apps -->
  <section id="apps" class="max-w-4xl mx-auto px-8 py-16">
    <h2 class="text-2xl font-bold mb-8">{t('apps.section_title')}</h2>

    <div class="grid gap-4 sm:grid-cols-2">
      <!-- Nudge PDF -->
      <div class="border border-gray-200 rounded-2xl p-6 flex flex-col gap-3 hover:border-gray-400 transition-colors">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="font-semibold text-lg">{t('apps.nudge_pdf.name')}</h3>
            <p class="text-sm text-gray-500 mt-0.5">{t('apps.nudge_pdf.tagline')}</p>
          </div>
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">
            {t('apps.free')}
          </span>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed">
          {t('apps.nudge_pdf.description')}
        </p>
        <a
          href="/downloads/nudge-pdf.dmg"
          class="mt-auto inline-flex items-center gap-2 bg-gray-900 text-white text-sm px-4 py-2 rounded-lg font-medium hover:bg-gray-700 transition-colors w-fit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          {t('apps.download')}
        </a>
      </div>
    </div>
  </section>
</Layout>
